# Fooocus/Gradio Server Configuration
# Copy this file to .env and edit with your server details

# Main Focus Server URL (where Gradio/Fooocus is running)
FOCUS_SERVER_URL=http://127.0.0.1:7865

# API Endpoint for inpainting generation (use /api/predict for Gradio)
API_ENDPOINT=/api/predict  # FIXED: Changed from 'generation/image-inpaint' to standard Gradio predict endpoint

# Optional: Custom timeout in milliseconds (default: 300000 / 5 minutes)
TIMEOUT_MS=300000

# Enable debug mode (logs API requests)
DEBUG_MODE=false
